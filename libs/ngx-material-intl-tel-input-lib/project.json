  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:ng-packagr",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/ngx-material-intl-tel-input-lib/ng-package.json",
        "tsConfig": "libs/ngx-material-intl-tel-input-lib/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/ngx-material-intl-tel-input-lib/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "tsConfig": "libs/ngx-material-intl-tel-input-lib/tsconfig.spec.json",
        "buildTarget": "ngx-material-intl-tel-input-lib::development"
      }
    }
  }
